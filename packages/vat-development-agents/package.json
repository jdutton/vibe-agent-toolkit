{
  "name": "@vibe-agent-toolkit/vat-development-agents",
  "version": "0.1.15-rc.6",
  "description": "VAT development agents - dogfooding the vibe-agent-toolkit",
  "type": "module",
  "keywords": [
    "vat-agent",
    "vibe-agent",
    "agent-bundle",
    "development-tools"
  ],
  "vat": {
    "version": "1.0",
    "type": "agent-bundle",
    "skills": [
      {
        "name": "vibe-agent-toolkit",
        "source": "./resources/skills/SKILL.md",
        "path": "./dist/skills/vibe-agent-toolkit",
        "packagingOptions": { "linkFollowDepth": 0 }
      },
      {
        "name": "vibe-agent-toolkit:resources",
        "source": "./resources/skills/vat-resources.md",
        "path": "./dist/skills/vibe-agent-toolkit-resources"
      },
      {
        "name": "vibe-agent-toolkit:distribution",
        "source": "./resources/skills/vat-distribution.md",
        "path": "./dist/skills/vibe-agent-toolkit-distribution"
      },
      {
        "name": "vibe-agent-toolkit:agent-authoring",
        "source": "./resources/skills/vat-agent-authoring.md",
        "path": "./dist/skills/vibe-agent-toolkit-agent-authoring",
        "packagingOptions": { "linkFollowDepth": 0 }
      },
      {
        "name": "vibe-agent-toolkit:audit",
        "source": "./resources/skills/vat-audit.md",
        "path": "./dist/skills/vibe-agent-toolkit-audit"
      }
    ],
    "agents": [
      {
        "name": "agent-generator",
        "path": "./agents/agent-generator",
        "type": "meta-agent"
      },
      {
        "name": "resource-optimizer",
        "path": "./agents/resource-optimizer",
        "type": "pure-function"
      }
    ]
  },
  "exports": {
    "./agents/agent-generator": "./agents/agent-generator/agent.yaml",
    "./agents/resource-optimizer": "./agents/resource-optimizer/SCOPE.md"
  },
  "files": [
    "dist",
    "agents",
    "README.md"
  ],
  "scripts": {
    "generate:resources": "vat-compile-resources compile resources/ generated/resources/",
    "build:code": "bun run generate:resources && tspc && bun scripts/post-build.ts",
    "build:skills": "node ../cli/dist/bin/vat.js skills build",
    "build:vat": "node ../cli/dist/bin/vat.js build",
    "build": "bun run build:code && bun run build:vat",
    "test:pipeline": "bun run build && bun run dist/src/test-pipeline.js",
    "typecheck": "tsc --noEmit",
    "validate": "bun run agents/agent-generator/validate-agent.ts",
    "postinstall": "vat skills install --npm-postinstall || exit 0"
  },
  "dependencies": {
    "@vibe-agent-toolkit/agent-schema": "workspace:*",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vibe-agent-toolkit/resource-compiler": "workspace:*",
    "ts-patch": "^3.2.1",
    "typescript": "^5.7.3"
  },
  "author": "VAT Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jdutton/vibe-agent-toolkit.git"
  }
}
