{
  "name": "@vibe-agent-toolkit/vat-development-agents",
  "version": "0.1.26",
  "description": "VAT development agents - dogfooding the vibe-agent-toolkit",
  "type": "module",
  "keywords": [
    "vat-agent",
    "vibe-agent",
    "agent-bundle",
    "development-tools"
  ],
  "vat": {
    "version": "1.0",
    "skills": [
      "vibe-agent-toolkit",
      "resources",
      "distribution",
      "authoring",
      "audit",
      "debugging",
      "install"
    ],
    "replaces": {
      "plugins": ["vat-development-agents"],
      "flatSkills": ["vibe-agent-toolkit", "resources"]
    },
    "agents": [
      {
        "name": "agent-generator",
        "path": "./agents/agent-generator",
        "type": "meta-agent"
      },
      {
        "name": "resource-optimizer",
        "path": "./agents/resource-optimizer",
        "type": "pure-function"
      }
    ]
  },
  "exports": {
    "./package.json": "./package.json",
    "./agents/agent-generator": "./agents/agent-generator/agent.yaml",
    "./agents/resource-optimizer": "./agents/resource-optimizer/SCOPE.md"
  },
  "files": [
    "dist",
    "agents",
    "README.md"
  ],
  "scripts": {
    "generate:resources": "vat-compile-resources compile resources/ generated/resources/",
    "build:code": "bun run generate:resources && tspc && bun scripts/post-build.ts",
    "build:skills": "node ../cli/dist/bin/vat.js skills build",
    "build:vat": "node ../cli/dist/bin/vat.js build",
    "build": "bun run build:code && bun run build:vat",
    "test:pipeline": "bun run build && bun run dist/src/test-pipeline.js",
    "typecheck": "tsc --noEmit",
    "validate": "bun run agents/agent-generator/validate-agent.ts",
    "postinstall": "vat claude plugin install --npm-postinstall || exit 0"
  },
  "dependencies": {
    "@vibe-agent-toolkit/agent-schema": "workspace:*",
    "@vibe-agent-toolkit/cli": "workspace:*",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vibe-agent-toolkit/resource-compiler": "workspace:*",
    "ts-patch": "^3.2.1",
    "typescript": "^5.7.3"
  },
  "author": "VAT Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jdutton/vibe-agent-toolkit.git"
  }
}
